{
  "build": {
    "devPath": "../public",
    "distDir": "../public",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Glide",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "",
      "deb": { "depends": ["libssl1.1"] },
      "icon": [],
      "identifier": "xyz.soocoo.glide",
      "longDescription": "LAN-first clipboard sync across devices",
      "shortDescription": "Clipboard sync tool",
      "targets": ["deb", "appimage", "msi", "nsis"]
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src *"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 480,
        "resizable": true,
        "title": "Glide",
        "width": 360
      }
    ]
  }
}
