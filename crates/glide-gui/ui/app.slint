import { Sidebar, TopBar, DeviceRow } from "components.slint";
import { StatusPage, DevicesPage, PairingPage, LogPage, SettingsPage, PlatformPage, AboutPage } from "pages.slint";
import { MonitorManagerPage, MonitorInfo } from "monitor_manager.slint";
import { AppColors } from "colors.slint";

// === Main Window ===

export component MainWindow inherits Window {
    title: "Glide";
    preferred-width: 860px;
    preferred-height: 590px;
    min-width: 720px;
    min-height: 500px;
    background: AppColors.page-bg;
    animate background { duration: 200ms; }

    // === Existing properties (required by main.rs) ===
    in-out property <int> current-page: 0;
    in-out property <bool> service-running: true;
    in-out property <string> connection-status: "未连接";
    in-out property <string> device-count-text: "0";
    in-out property <string> server-url: "";

    in-out property <string> device-name: "";
    in-out property <bool> clipboard-enabled: true;
    in-out property <bool> input-enabled: false;
    in-out property <string> log-content: "";
    in-out property <string> platform-summary: "";
    in-out property <[DeviceRow]> devices: [];
    in-out property <bool> dark-mode: false;
    in-out property <string> auth-username: "";
    in-out property <string> auth-password: "";
    in-out property <[MonitorInfo]> monitors: [];
    in-out property <string> monitor-status: "未检测";
    in-out property <int> total-devices: 0;
    in-out property <int> online-devices: 0;

    // === Existing callbacks (required by main.rs) ===
    callback page-changed(int);
    callback connect();
    callback disconnect();
    callback toggle-clipboard();
    callback toggle-input();
    callback trust-device(string);
    callback untrust-device(string);
    callback remove-device(string);
    callback save-server(string);
    callback save-name(string);
    callback toggle-theme();
    callback save-auth(string, string);
    callback detect-monitors();
    callback save-monitor-layout();
    callback monitor-selected(string);

    HorizontalLayout {
        Sidebar {
            current-index: current-page;
            page-selected(index) => { root.page-changed(index); }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            TopBar {
                title: current-page == 0 ? "状态" :
                    current-page == 1 ? "设备" :
                    current-page == 2 ? "配对" :
                    current-page == 3 ? "日志" :
                    current-page == 4 ? "设置" :
                    current-page == 5 ? "平台能力" :
                    current-page == 6 ? "显示器管理" : "关于";
                connection-status: connection-status;
            }

            if current-page == 0 : StatusPage {
                service-running: service-running;
                connection-status: connection-status;
                device-count-text: device-count-text;
                server-url: server-url;
                clipboard-enabled: clipboard-enabled;
                input-enabled: input-enabled;
                connect => { root.connect(); }
                disconnect => { root.disconnect(); }
                toggle-clipboard => { root.toggle-clipboard(); }
                toggle-input => { root.toggle-input(); }
            }
            if current-page == 1 : DevicesPage {
                devices: devices;
                total-devices: total-devices;
                online-devices: online-devices;
                trust-device(id) => { root.trust-device(id); }
                untrust-device(id) => { root.untrust-device(id); }
                remove-device(id) => { root.remove-device(id); }
            }
            if current-page == 2 : PairingPage {}
            if current-page == 3 : LogPage { log-content: log-content; }
            if current-page == 4 : SettingsPage {
                server-url: server-url;
                device-name: device-name;
                dark-mode: dark-mode;
                auth-username: auth-username;
                auth-password: auth-password;
                save-server(url) => { root.save-server(url); }
                save-name(name) => { root.save-name(name); }
                toggle-theme => {
                    root.dark-mode = !root.dark-mode;
                    AppColors.dark-mode = root.dark-mode;
                }
                save-auth(user, pass) => { root.save-auth(user, pass); }
            }
            if current-page == 5 : PlatformPage { platform-summary: platform-summary; }
            if current-page == 6 : MonitorManagerPage {
                monitors: monitors;
                status-text: monitor-status;
                detect-monitors => { root.detect-monitors(); }
                save-layout => { root.save-monitor-layout(); }
                monitor-selected(id) => { root.monitor-selected(id); }
            }
            if current-page == 7 : AboutPage {}
        }
    }
}
