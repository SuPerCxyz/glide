import { ScrollView } from "std-widgets.slint";
import { AppColors } from "colors.slint";
import { PageButton, SectionTitle, AlertBox } from "components.slint";

export struct MonitorInfo {
    monitor-id: string,
    name: string,
    width: int,
    height: int,
    x-offset: int,
    y-offset: int,
    is-primary: bool,
}

component MonitorCard inherits Rectangle {
    in property <MonitorInfo> monitor;
    callback clicked();

    min-height: 74px;
    background: AppColors.page-surface;
    border-radius: 8px;
    border-width: 1px;
    border-color: touch-area.has-hover ? AppColors.border-focus : AppColors.border-base;
    animate border-color { duration: 150ms; }

    touch-area := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding: 16px;
        spacing: 16px;
        alignment: start;

        Rectangle {
            width: 38px;
            height: 38px;
            background: AppColors.primary-subtle;
            border-radius: 8px;

            VerticalLayout {
                alignment: center;
                Text {
                    text: "M";
                    font-size: 16px;
                    font-weight: 700;
                    color: AppColors.primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Monitor info
        VerticalLayout {
            spacing: 4px;
            horizontal-stretch: 1;

            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Text {
                    text: monitor.name;
                    font-size: 15px;
                    font-weight: 600;
                    color: AppColors.text-primary;
                }
                if monitor.is-primary : Rectangle {
                    width: 60px;
                    height: 20px;
                    background: AppColors.primary;
                    border-radius: 4px;

                    Text {
                        text: "主显示器";
                        font-size: 11px;
                        font-weight: 500;
                        color: AppColors.text-inverse;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Text {
                text: monitor.width + " x " + monitor.height + " @ (" + monitor.x-offset + ", " + monitor.y-offset + ")";
                font-size: 13px;
                color: AppColors.text-secondary;
            }
        }

        Rectangle {
            width: 60px;
            height: 38px;
            background: AppColors.page-surface-alt;
            border-radius: 4px;
            border-width: 1px;
            border-color: AppColors.border-base;

            VerticalLayout {
                alignment: center;
                Text {
                    text: "位置";
                    font-size: 10px;
                    color: AppColors.text-tertiary;
                    horizontal-alignment: center;
                }
                Text {
                    text: "(" + monitor.x-offset + "," + monitor.y-offset + ")";
                    font-size: 11px;
                    font-weight: 500;
                    color: AppColors.text-primary;
                    horizontal-alignment: center;
                }
            }
        }
    }
}

export component MonitorManagerPage inherits VerticalLayout {
    in property <length> available-width: 800px;
    width: 100%;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    in property <[MonitorInfo]> monitors: [];
    in property <string> status-text: "未检测";
    callback detect-monitors();
    callback save-layout();
    callback monitor-selected(string);

    scroll := ScrollView {
        vertical-stretch: 1;
        width: 100%;
        viewport-width: self.width;
        HorizontalLayout {
            width: scroll.visible-width;
            Rectangle { width: 24px; }
            Rectangle {
                horizontal-stretch: 1;
                min-width: available-width - 48px;
                VerticalLayout {
                    padding-top: 22px;
                    padding-bottom: 24px;
                    spacing: 16px;
                    width: 100%;
                    alignment: stretch;

                    HorizontalLayout {
                        alignment: start;
                        spacing: 12px;
                        SectionTitle { label: "显示器布局"; }
                        Rectangle { width: 1px; height: 22px; background: AppColors.border-base; }
                        Text { text: status-text; font-size: 13px; color: AppColors.text-secondary; vertical-alignment: center; }
                    }

                    Rectangle {
                        background: AppColors.page-surface;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: AppColors.border-base;
                        min-height: 280px;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;

                            Text { text: "检测到的显示器"; font-size: 15px; font-weight: 700; color: AppColors.text-primary; }

                            VerticalLayout {
                                spacing: 10px;
                                for monitor in monitors : MonitorCard {
                                    monitor: monitor;
                                    clicked => { root.monitor-selected(monitor.monitor-id); }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                alignment: end;
                                PageButton { text: "重新检测"; clicked => { root.detect-monitors(); } }
                                PageButton { text: "保存布局"; variant: "primary"; clicked => { root.save-layout(); } }
                            }
                        }
                    }

                    AlertBox {
                        alert-title: "用途";
                        body: "显示器管理器用于配置多显示器环境下的鼠标键盘共享。调整显示器位置以匹配物理布局。";
                        alert-type: "info";
                    }
                }
            }
            Rectangle { width: 24px; }
        }
    }
}
