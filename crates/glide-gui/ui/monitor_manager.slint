import { Button, ScrollView } from "std-widgets.slint";
import { AppColors } from "colors.slint";

export struct MonitorInfo {
    monitor-id: string,
    name: string,
    width: int,
    height: int,
    x-offset: int,
    y-offset: int,
    is-primary: bool,
}

component MonitorCard inherits Rectangle {
    in property <MonitorInfo> monitor;
    callback clicked();

    height: 80px;
    background: AppColors.page-surface;
    border-radius: 8px;
    border-width: 1px;
    border-color: touch-area.has-hover ? AppColors.border-focus : AppColors.border-base;
    animate border-color { duration: 150ms; }

    touch-area := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding: 16px;
        spacing: 16px;
        alignment: start;

        // Monitor icon
        Rectangle {
            width: 48px;
            height: 48px;
            background: AppColors.primary-subtle;
            border-radius: 8px;

            VerticalLayout {
                alignment: center;
                Text {
                    text: "🖥️";
                    font-size: 24px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Monitor info
        VerticalLayout {
            spacing: 4px;
            horizontal-stretch: 1;

            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Text {
                    text: monitor.name;
                    font-size: 15px;
                    font-weight: 600;
                    color: AppColors.text-primary;
                }
                if monitor.is-primary : Rectangle {
                    width: 60px;
                    height: 20px;
                    background: AppColors.primary;
                    border-radius: 4px;

                    Text {
                        text: "主显示器";
                        font-size: 11px;
                        font-weight: 500;
                        color: AppColors.text-inverse;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Text {
                text: monitor.width + " x " + monitor.height + " @ (" + monitor.x-offset + ", " + monitor.y-offset + ")";
                font-size: 13px;
                color: AppColors.text-secondary;
            }
        }

        // Position indicator
        Rectangle {
            width: 60px;
            height: 40px;
            background: AppColors.page-surface-alt;
            border-radius: 4px;
            border-width: 1px;
            border-color: AppColors.border-base;

            VerticalLayout {
                alignment: center;
                Text {
                    text: "位置";
                    font-size: 10px;
                    color: AppColors.text-tertiary;
                    horizontal-alignment: center;
                }
                Text {
                    text: "(" + monitor.x-offset + "," + monitor.y-offset + ")";
                    font-size: 11px;
                    font-weight: 500;
                    color: AppColors.text-primary;
                    horizontal-alignment: center;
                }
            }
        }
    }
}

export component MonitorManagerPage inherits VerticalLayout {
    in property <[MonitorInfo]> monitors: [];
    in property <string> status-text: "未检测";
    callback detect-monitors();
    callback save-layout();
    callback monitor-selected(string);

    ScrollView {
        VerticalLayout {
            padding: 24px;
            spacing: 20px;

            // Header
            HorizontalLayout {
                alignment: start;
                spacing: 12px;
                Text {
                    text: "显示器管理器";
                    font-size: 24px;
                    font-weight: 700;
                    color: AppColors.text-primary;
                    vertical-alignment: center;
                }
                Rectangle { width: 1px; height: 24px; background: AppColors.border-base; }
                Text {
                    text: status-text;
                    font-size: 14px;
                    color: AppColors.text-secondary;
                    vertical-alignment: center;
                }
            }

            // Visualization area
            Rectangle {
                background: AppColors.page-surface;
                border-radius: 8px;
                border-width: 1px;
                border-color: AppColors.border-base;
                min-height: 300px;

                VerticalLayout {
                    padding: 20px;
                    spacing: 16px;

                    // Title
                    Text {
                        text: "显示器布局";
                        font-size: 16px;
                        font-weight: 600;
                        color: AppColors.text-primary;
                    }

                    // Monitor visualization (simplified - shows list)
                    VerticalLayout {
                        spacing: 12px;
                        for monitor in monitors : MonitorCard {
                            monitor: monitor;
                            clicked => { root.monitor-selected(monitor.monitor-id); }
                        }
                    }

                    // Action buttons
                    HorizontalLayout {
                        spacing: 12px;
                        alignment: end;
                        Button {
                            text: "重新检测";
                            clicked => { root.detect-monitors(); }
                        }
                        Button {
                            text: "保存布局";
                            clicked => { root.save-layout(); }
                        }
                    }
                }
            }

            // Help text
            Rectangle {
                background: AppColors.alert-info-bg;
                border-radius: 8px;
                border-width: 1px;
                border-color: AppColors.alert-info-border;
                height: 60px;

                HorizontalLayout {
                    padding: 16px;
                    spacing: 12px;
                    alignment: start;
                    Text {
                        text: "💡";
                        font-size: 20px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "显示器管理器用于配置多显示器环境下的鼠标键盘共享。调整显示器位置以匹配物理布局，实现无缝切换。";
                        font-size: 13px;
                        color: AppColors.alert-info-text;
                        wrap: word-wrap;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }
            }
        }
    }
}
