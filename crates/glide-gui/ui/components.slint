import { Switch } from "std-widgets.slint";
import { AppColors } from "colors.slint";

export struct DeviceRow {
    name: string,
    platform: string,
    status: string,
    device-id: string,
    trusted: bool,
    is-lan: bool,
}

component SidebarItem inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <int> index;
    in property <int> current-index;
    callback page-selected(int);
    height: 38px;
    border-radius: 8px;
    background: index == current-index ? AppColors.sidebar-active : ta.has-hover ? AppColors.button-ghost-hover : transparent;
    animate background { duration: 150ms; }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.page-selected(index); }
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: start;
        Text { text: icon; font-size: 14px; width: 22px; color: index == current-index ? AppColors.sidebar-active-text : AppColors.sidebar-text; vertical-alignment: center; }
        Text {
            text: label;
            font-size: 14px;
            font-weight: index == current-index ? 600 : 400;
            color: index == current-index ? AppColors.sidebar-active-text : AppColors.sidebar-text;
            vertical-alignment: center;
            animate color { duration: 150ms; }
        }
    }
}

export component Sidebar inherits Rectangle {
    in property <int> current-index;
    callback page-selected(int);
    width: 228px;
    background: AppColors.sidebar-bg;
    Rectangle { x: 227px; width: 1px; height: 100%; background: AppColors.border-base; }
    VerticalLayout {
        padding-top: 18px; padding-bottom: 16px;
        padding-left: 14px; padding-right: 14px;
        spacing: 4px;
        Rectangle {
            height: 46px;
            HorizontalLayout {
                padding-left: 10px;
                alignment: start;
                Rectangle { width: 24px; height: 24px; border-radius: 6px; background: AppColors.primary; }
                Text { text: "Glide"; font-size: 22px; font-weight: 800; color: AppColors.text-primary; vertical-alignment: center; }
            }
        }
        Rectangle { height: 1px; background: AppColors.border-base; }
        Rectangle { height: 8px; }
        SidebarItem { icon: "S"; label: "状态";     index: 0; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
        SidebarItem { icon: "D"; label: "设备";     index: 1; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
        SidebarItem { icon: "P"; label: "配对";     index: 2; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
        SidebarItem { icon: "≡"; label: "日志";     index: 3; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
        SidebarItem { icon: "*"; label: "设置";     index: 4; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
        SidebarItem { icon: "C"; label: "平台能力"; index: 5; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
        SidebarItem { icon: "M"; label: "显示器";   index: 6; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
        SidebarItem { icon: "i"; label: "关于";     index: 7; current-index: current-index; page-selected(idx) => { root.page-selected(idx); } }
    }
}

export component StatusBadge inherits Rectangle {
    in property <string> label;
    in property <color> badge-color: AppColors.text-tertiary;
    in property <color> badge-bg: AppColors.page-surface-alt;
    in property <bool> pulse: false;
    min-width: 74px;
    height: 24px;
    border-radius: 6px;
    background: badge-bg;
    HorizontalLayout {
        padding-left: 10px; padding-right: 10px;
        spacing: 6px;
        alignment: center;
        Rectangle { width: 8px; height: 8px; border-radius: 4px; background: badge-color; }
        Text { text: label; font-size: 13px; font-weight: 500; color: badge-color; vertical-alignment: center; }
    }
}

export component TopBar inherits Rectangle {
    in property <string> title;
    in property <string> connection-status;
    height: 56px;
    background: AppColors.page-bg;
    Rectangle { height: 1px; background: AppColors.border-base; y: 55px; width: 100%; }
    HorizontalLayout {
        padding-left: 24px; padding-right: 24px;
        HorizontalLayout {
            horizontal-stretch: 1;
            alignment: start;
            Text { text: title; font-size: 20px; font-weight: 700; color: AppColors.text-primary; vertical-alignment: center; }
        }
        Rectangle { horizontal-stretch: 1; }
        Text { text: "连接"; font-size: 13px; color: AppColors.text-secondary; vertical-alignment: center; }
        Rectangle { width: 8px; }
        StatusBadge {
            label: connection-status;
            badge-color: connection-status == "已连接" ? AppColors.status-online : connection-status == "未连接" ? AppColors.status-offline : connection-status == "连接中" ? AppColors.status-connecting : AppColors.status-unpaired;
            badge-bg: connection-status == "已连接" ? AppColors.status-online-bg : connection-status == "未连接" ? AppColors.status-offline-bg : connection-status == "连接中" ? AppColors.status-connecting-bg : AppColors.status-unpaired-bg;
        }
    }
}

export component SectionTitle inherits HorizontalLayout {
    in property <string> label;
    spacing: 8px;
    alignment: start;
    Rectangle { width: 3px; height: 17px; border-radius: 2px; background: AppColors.primary; }
    Text { text: label; font-size: 15px; font-weight: 700; color: AppColors.text-primary; vertical-alignment: center; }
}

export component PageButton inherits Rectangle {
    in property <string> text;
    in property <string> variant: "secondary";
    in property <bool> prominent: false;
    callback clicked();
    min-width: prominent ? 86px : 70px;
    height: prominent ? 38px : 34px;
    border-radius: 7px;
    border-width: 1px;
    border-color: variant == "primary" ? AppColors.button-primary-bg :
        variant == "danger" ? AppColors.alert-danger-border : AppColors.border-base;
    background: variant == "primary" ? (ta.has-hover ? AppColors.primary-hover : AppColors.button-primary-bg) :
        variant == "danger" ? (ta.has-hover ? AppColors.alert-danger-bg : AppColors.page-elevated) :
        (ta.has-hover ? AppColors.button-secondary-hover : AppColors.page-elevated);
    animate background { duration: 120ms; }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    Text {
        text: root.text;
        font-size: 13px;
        font-weight: variant == "primary" ? 600 : 500;
        color: variant == "primary" ? AppColors.button-primary-text :
            variant == "danger" ? AppColors.alert-danger-text : AppColors.button-secondary-text;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component MetricCard inherits Rectangle {
    in property <string> title;
    in property <string> value;
    in property <string> detail;
    in property <string> state: "muted";
    min-height: 96px;
    width: 100%;
    horizontal-stretch: 1;
    background: AppColors.page-surface;
    border-radius: 10px;
    border-width: 1px;
    border-color: AppColors.border-base;
    HorizontalLayout {
        padding: 16px;
        spacing: 12px;
        alignment: start;
        Rectangle {
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: state == "success" ? AppColors.status-online :
                state == "warning" ? AppColors.status-limited :
                state == "error" ? AppColors.status-error :
                state == "connecting" ? AppColors.status-connecting : AppColors.status-unpaired;
        }
        VerticalLayout {
            spacing: 4px;
            horizontal-stretch: 1;
            Text { text: title; font-size: 13px; font-weight: 600; color: AppColors.text-secondary; }
            Text { text: value; font-size: 16px; font-weight: 700; color: AppColors.text-primary; wrap: word-wrap; }
            Text { text: detail; font-size: 12px; color: AppColors.text-tertiary; wrap: word-wrap; }
        }
    }
}

export component AlertBox inherits Rectangle {
    in property <string> alert-title;
    in property <string> body;
    in property <string> alert-type: "info";
    border-radius: 8px;
    width: 100%;
    horizontal-stretch: 1;
    background: alert-type == "info" ? AppColors.alert-info-bg : alert-type == "warning" ? AppColors.alert-warning-bg : alert-type == "success" ? AppColors.alert-success-bg : AppColors.alert-danger-bg;
    HorizontalLayout {
        Rectangle { width: 4px; border-radius: 2px; background: alert-type == "info" ? AppColors.alert-info-border : alert-type == "warning" ? AppColors.alert-warning-border : alert-type == "success" ? AppColors.alert-success-border : AppColors.alert-danger-border; }
        HorizontalLayout {
            padding: 14px;
            VerticalLayout {
                spacing: 4px;
                Text { text: alert-title; font-size: 15px; font-weight: 600; color: alert-type == "info" ? AppColors.alert-info-text : alert-type == "warning" ? AppColors.alert-warning-text : alert-type == "success" ? AppColors.alert-success-text : AppColors.alert-danger-text; }
                Text { text: body; font-size: 14px; color: alert-type == "info" ? AppColors.alert-info-text : alert-type == "warning" ? AppColors.alert-warning-text : alert-type == "success" ? AppColors.alert-success-text : AppColors.alert-danger-text; wrap: word-wrap; }
            }
        }
    }
}

export component DeviceCard inherits Rectangle {
    in property <string> device-name;
    in property <string> device-platform;
    in property <string> status-text;
    in property <string> device-id;
    in property <bool> is-online;
    in property <bool> is-trusted;
    in property <bool> is-lan;
    callback trust-request(string);
    callback untrust-request(string);
    callback remove-request(string);
    min-height: 70px;
    width: 100%;
    horizontal-stretch: 1;
    background: AppColors.page-surface;
    border-radius: 8px;
    border-width: 1px;
    border-color: AppColors.border-base;
    property <bool> hovered: touch-area.has-hover;
    touch-area := TouchArea { mouse-cursor: pointer; }
    HorizontalLayout {
        padding-left: 16px; padding-right: 16px;
        spacing: 14px;
        alignment: start;
        Rectangle { width: 36px; height: 36px; border-radius: 8px; background: is-online ? AppColors.status-online-bg : AppColors.status-offline-bg;
            VerticalLayout { alignment: center; Text { text: ""; font-size: 18px; } }
        }
        VerticalLayout {
            spacing: 3px; horizontal-stretch: 1;
            alignment: start;
            Text { text: device-name; font-size: 15px; font-weight: 600; color: AppColors.text-primary; }
            Text { text: device-platform; font-size: 13px; color: AppColors.text-secondary; }
        }
        StatusBadge { label: is-trusted ? "已信任" : "未信任"; badge-color: is-trusted ? AppColors.status-online : AppColors.status-unpaired; badge-bg: is-trusted ? AppColors.status-online-bg : AppColors.status-unpaired-bg; }
        StatusBadge { label: status-text; badge-color: is-online ? AppColors.status-online : AppColors.status-offline; badge-bg: is-online ? AppColors.status-online-bg : AppColors.status-offline-bg; }
        if is-lan && !is-trusted : PageButton { text: "信任"; variant: "primary"; clicked => { root.trust-request(device-id); } }
        if is-lan && is-trusted : PageButton { text: "取消信任"; clicked => { root.untrust-request(device-id); } }
        PageButton { text: "移除"; variant: "danger"; clicked => { root.remove-request(device-id); } }
    }
}

export component SettingsRow inherits Rectangle {
    in property <string> label;
    in property <string> detail;
    in property <bool> checked;
    callback toggled();
    min-height: 58px;
    width: 100%;
    horizontal-stretch: 1;
    background: AppColors.page-surface;
    border-radius: 10px;
    border-width: 1px;
    border-color: AppColors.border-base;
    HorizontalLayout {
        padding-left: 16px; padding-right: 16px;
        spacing: 14px;
        alignment: start;
        VerticalLayout {
            spacing: 3px; horizontal-stretch: 1;
            alignment: start;
            Text { text: label; font-size: 15px; font-weight: 600; color: AppColors.text-primary; }
            Text { text: detail; font-size: 13px; color: AppColors.text-secondary; }
        }
        Switch { checked: root.checked; toggled => { root.toggled(); } }
    }
}
